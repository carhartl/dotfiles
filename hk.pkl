amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["newlines"] = Builtins.newlines
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["prettier"] = Builtins.prettier
  ["shellcheck"] = (Builtins.shellcheck) {
    glob = "bin/*"
  }
  // Custom shfmt linter - we need to avoid `--apply-ignore`, otherwise Zsh config files will be ignored..
  // https://github.com/jdx/hk/discussions/790
  //
  // The overlap of `bin/*` with the shellcheck linter seems to be ok,
  // shellcheck doesn't autofix.
  ["shfmt"] {
    batch = true
    glob = List("bin/*", "zsh/functions/*", "**/*.zsh", ".zprofile", ".zshenv", ".zshrc")
    check_diff = "shfmt -l {{ files }}"
    check = "shfmt -d {{ files }}"
    check_list_files =
      """
      files=$(shfmt -l {{ files }})
      if [ -n "$files" ]; then
        echo "$files"
        exit 1
      fi
      """
    fix = "shfmt -w {{ files }}"
  }
  ["trailing-whitespace"] = Builtins.trailing_whitespace
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = false // Required to make the shfmt linter work for now - https://github.com/jdx/hk/discussions/790
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
