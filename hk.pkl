amends "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["newlines"] = Builtins.newlines
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["prettier"] = Builtins.prettier
  ["shellcheck"] = (Builtins.shellcheck) {
    types = List("shell")
  }
  ["shfmt"] = (Builtins.shfmt) {
    glob =
      List(
        "bin/[!2]*", // Must exclude bin/2date, which is a Ruby script
        "*.zfunctions/*",
        "*.zshrc.d/*",
        "*.zprofile",
        "*.zshenv",
        "*.zshrc",
        "*.zstyles",
      )
  }
  ["trailing-whitespace"] = Builtins.trailing_whitespace
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = true
    steps = linters
  }
  ["fix"] {
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
