amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["newlines"] = Builtins.newlines
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["prettier"] = Builtins.prettier
  ["shellcheck"] = (Builtins.shellcheck) {
    types = List("shell")
  }
  ["shfmt"] = (Builtins.shfmt) {
    // Must exclude bin/2date, which is a Ruby script
    glob = List("bin/[!2]*", "zsh/functions/*", "**/*.zsh", ".zprofile", ".zshenv", ".zshrc")
  }
  ["trailing-whitespace"] = Builtins.trailing_whitespace
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = false // Required to make the shfmt linter work for now - https://github.com/jdx/hk/discussions/790
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
