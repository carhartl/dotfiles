// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `zed: Open Default Settings` command
// from the command palette
{
  "active_pane_modifiers": {
    "inactive_opacity": 0.8
  },
  "agent": {
    "default_profile": "ask",
    "inline_assistant_model": {
      "model": "claude-3-7-sonnet-latest",
      "provider": "zed.dev"
    },
    "default_model": {
      "model": "gpt-5.3-codex",
      "provider": "copilot_chat"
    }
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.3-codex",
        "reasoning_effort": "medium"
      },
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "comment": true,
    "dockerfile": true,
    "editorconfig": true,
    "github-theme": true,
    "golangci-lint": true,
    "html": true,
    "java": true,
    "pkl": true,
    "ruby": true,
    "ruff": true,
    "terraform": true,
    "tokyo-night": true,
    "toml": true
  },
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "ss09": true
  },
  "buffer_font_size": 16,
  "collaboration_panel": {
    "button": false
  },
  "colorize_brackets": true,
  "edit_predictions": {
    "enabled_in_text_threads": false,
    "mode": "subtle",
    "provider": "copilot"
  },
  "file_types": {
    "Dockerfile": ["Dockerfile*"]
  },
  "git": {
    "blame": {
      "show_avatar": true
    }
  },
  "git_panel": {
    "default_width": 550
  },
  "indent_guides": {
    "coloring": "indent_aware"
  },
  "inlay_hints": {
    "enabled": true
  },
  "languages": {
    "Java": {
      "code_actions_on_format": {
        "quickfix": true,
        "source": true
      },
      "formatter": "language_server",
      "hard_tabs": false, // for Google Java Style
      "tab_size": 2 // for Google Java Style
    },
    "JavaScript": {
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "arguments": ["--stdin-filepath", "{buffer_path}", "--no-semi"],
            "command": "prettier"
          }
        }
      ]
    },
    // Workaround for https://github.com/prettier/prettier/issues/15956
    "JSONC": {
      "formatter": [
        {
          "external": {
            "arguments": [
              "--stdin-filepath",
              "{buffer_path}",
              "--trailing-comma",
              "none"
            ],
            "command": "prettier"
          }
        }
      ]
    },
    "Markdown": {
      "format_on_save": "on"
    },
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true
      },
      "language_servers": [
        // Disable basedpyright and enable ty, and otherwise
        // use the default configuration.
        "ty",
        "!basedpyright",
        "..."
      ]
    },
    "Ruby": {
      "language_servers": ["ruby-lsp"]
    },
    "Shell Script": {
      "formatter": {
        "external": {
          "arguments": ["--filename", "{buffer_path}"],
          "command": "shfmt"
        }
      },
      "hard_tabs": true,
      "tab_size": 4
    }
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "staticcheck": true
      }
    },
    "jdtls": {
      "initialization_options": {
        "settings": {
          "java": {
            "cleanup": {
              "actions": [
                "addDeprecated",
                "addFinalModifier",
                "addOverride",
                "instanceofPatternMatch",
                "invertEquals",
                "lambdaExpression",
                "lambdaExpressionFromAnonymousClass",
                "organizeImports",
                "qualifyMembers",
                "qualifyStaticMembers",
                "redundantComparisonStatement",
                "redundantFallingThroughBlockEnd",
                "redundantIfCondition",
                "redundantModifiers",
                "redundantSuperCall",
                "renameUnusedLocalVariables",
                "stringConcatToTextBlock",
                "switchExpression",
                "tryWithResource",
                "useSwitchForInstanceofPattern"
              ]
            },
            "format": {
              "onType": {
                "enabled": true
              },
              "settings": {
                "profile": "GoogleStyle",
                "url": "https://raw.githubusercontent.com/google/styleguide/gh-pages/eclipse-java-google-style.xml"
              }
            },
            "import": {
              "gradle": {
                "enabled": true,
                "wrapper": {
                  "enabled": true
                }
              }
            },
            "jdt": {
              "ls": {
                "groovySupport": {
                  "enabled": true
                }
              }
            },
            "sources": {
              "organizeImports": {
                "starThreshold": 5,
                "staticStarThreshold": 5
              }
            },
            "saveActions": {
              "cleanup": true,
              "organizeImports": false
            }
          }
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lint": {
            "select": ["B", "E", "F", "I", "SIM", "UP"]
          }
        }
      }
    },
    "terraform-ls": {
      "initialization_options": {
        "experimentalFeatures": {
          "prefillRequiredFields": true
        }
      }
    },
    "ty": {
      "binary": {
        "path": "/opt/homebrew/bin/ty",
        "arguments": ["server"]
      }
    }
  },
  "minimap": {
    "current_line_highlight": "gutter",
    "show": "always",
    "thumb_border": "none"
  },
  "outline_panel": {
    "default_width": 450
  },
  "preferred_line_length": 120,
  "profiles": {
    "Personal": {},
    "Work": {
      "edit_predictions": {
        "provider": "copilot"
      }
    }
  },
  "project_panel": {
    "default_width": 450,
    "git_status": true,
    "sticky_scroll": true
  },
  "rounded_selection": false,
  "scrollbar": {
    "show": "system"
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "show_whitespaces": "boundary",
  "soft_wrap": "editor_width",
  "sticky_scroll": {
    "enabled": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "terminal": {
    "copy_on_select": true,
    "default_height": 500
  },
  "theme": {
    "mode": "dark",
    "dark": "Hyper",
    "light": "GitHub Light"
  },
  "theme_overrides": {
    "Github Light": {
      "syntax": {
        "constant.comment.todo": {
          "color": "#9a6700ff",
          "font_style": "italic"
        },
        "property.comment.error": {
          "color": "#d1242fff",
          "font_style": "italic"
        },
        "string.comment.info": {
          "color": "#59636eff",
          "font_style": "italic"
        }
      }
    }
  },
  "title_bar": {
    "show_branch_icon": true
  },
  "ui_font_size": 16,
  "use_smartcase_search": true,
  "use_system_window_tabs": true,
  "wrap_guides": [120]
}
